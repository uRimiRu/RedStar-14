ntr-executive-tier-1-name = Станция
ntr-executive-tier-2-name = Команды реагирования
ntr-executive-tier-3-name = Персональное
ntr-executive-tier-4-name = Зловещее
ntr-executive-tier-5-name = Редкие платы
